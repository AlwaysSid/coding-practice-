class Solution {
    public int[] avoidFlood(int[] rains) {
        int[] ans=new int[rains.length];
        HashMap<Integer,Integer> full=new HashMap<>();
        TreeSet<Integer> Sunnydays=new TreeSet<>();

        for (int i = 0; i < rains.length; i++) {
            if (rains[i]==0){
                Sunnydays.add(i);
                ans[i]=1;
            }else{
                int lake =rains[i];
                if (full.containsKey(lake)){
                    Integer drainday=Sunnydays.ceiling(full.get(lake));
                    if(drainday==null) return new int[]{};
                    ans[drainday]=lake;
                    Sunnydays.remove(drainday);
                }
                full.put(lake,i);
                ans[i]=-1;
            }
        }
        return ans;

       
    }
}